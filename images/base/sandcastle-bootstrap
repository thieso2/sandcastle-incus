#!/usr/bin/env bash
set -euo pipefail

user_name="${SANDCASTLE_USER:-sandcastle}"
user_id="${SANDCASTLE_UID:-1000}"
group_id="${SANDCASTLE_GID:-1000}"
ssh_public_key="${SANDCASTLE_SSH_PUBLIC_KEY:-}"

if ! getent group "${user_name}" >/dev/null 2>&1; then
  groupadd --gid "${group_id}" "${user_name}"
fi

if ! id -u "${user_name}" >/dev/null 2>&1; then
  useradd --uid "${user_id}" --gid "${group_id}" --create-home --shell /bin/bash "${user_name}"
  usermod -aG sudo "${user_name}"
  printf '%s ALL=(ALL) NOPASSWD:ALL\n' "${user_name}" >/etc/sudoers.d/sandcastle-user
  chmod 0440 /etc/sudoers.d/sandcastle-user
fi

# Add user to docker group if it exists
if getent group docker >/dev/null 2>&1; then
  usermod -aG docker "${user_name}"
fi

install -d -o "${user_name}" -g "${user_name}" "/home/${user_name}"
install -d -o "${user_name}" -g "${user_name}" /workspace

bashrc="/home/${user_name}/.bashrc"
bash_profile="/home/${user_name}/.bash_profile"
touch "${bashrc}" "${bash_profile}"
chown "${user_name}:${user_name}" "${bashrc}" "${bash_profile}"

auth_sock_marker="# sandcastle ssh agent socket"
if ! grep -qF "${auth_sock_marker}" "${bashrc}"; then
  cat >>"${bashrc}" <<'EOF_AUTH_SOCK'

# sandcastle ssh agent socket
if [ -S "$HOME/.ssh/ssh_auth_sock" ]; then
  export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"
fi
EOF_AUTH_SOCK
fi

prompt_marker="# sandcastle prompt: full hostname"
if ! grep -qF "${prompt_marker}" "${bashrc}"; then
  cat >>"${bashrc}" <<'EOF_PROMPT'

# sandcastle prompt: full hostname
if [[ $- == *i* ]]; then
  PS1='\u@\H:\w\$ '
fi
EOF_PROMPT
fi

alias_marker="# sandcastle aliases: yolo codex"
if ! grep -qF "${alias_marker}" "${bashrc}"; then
  cat >>"${bashrc}" <<'EOF_ALIASES'

# sandcastle aliases: yolo codex
alias ycodex='codex --dangerously-bypass-approvals-and-sandbox'
alias yolo='claude --dangerously-skip-permissions'
EOF_ALIASES
fi

profile_marker="# sandcastle bash profile: source bashrc"
if ! grep -qF "${profile_marker}" "${bash_profile}"; then
  cat >>"${bash_profile}" <<'EOF_PROFILE'

# sandcastle bash profile: source bashrc
if [[ -f ~/.bashrc ]]; then
  . ~/.bashrc
fi
EOF_PROFILE
fi
chown "${user_name}:${user_name}" "${bashrc}" "${bash_profile}"

ssh_dir="/home/${user_name}/.ssh"
install -d -m 0700 -o "${user_name}" -g "${user_name}" "${ssh_dir}"
ssh_rc="${ssh_dir}/rc"
ssh_rc_marker="# sandcastle ssh agent socket"
if ! grep -qF "${ssh_rc_marker}" "${ssh_rc}" 2>/dev/null; then
  cat >>"${ssh_rc}" <<'EOF_SSH_RC'
# sandcastle ssh agent socket
if [ -n "${SSH_AUTH_SOCK:-}" ] && [ ! -S "$HOME/.ssh/ssh_auth_sock" ] && [ -S "$SSH_AUTH_SOCK" ]; then
  ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock"
fi
EOF_SSH_RC
fi
chown "${user_name}:${user_name}" "${ssh_rc}"
chmod 0600 "${ssh_rc}"

# Inject SSH public key for both root and the Sandcastle user
if [[ -n "${ssh_public_key}" ]]; then
  for home_dir in /root "/home/${user_name}"; do
    install -d -m 0700 -o root -g root "${home_dir}/.ssh" 2>/dev/null || true
    chown "${user_name}:${user_name}" "/home/${user_name}/.ssh" 2>/dev/null || true
    auth_keys="${home_dir}/.ssh/authorized_keys"
    if ! grep -qF "${ssh_public_key}" "${auth_keys}" 2>/dev/null; then
      printf '%s\n' "${ssh_public_key}" >> "${auth_keys}"
    fi
    chmod 0600 "${auth_keys}"
  done
  chown -R "${user_name}:${user_name}" "/home/${user_name}/.ssh"
fi
