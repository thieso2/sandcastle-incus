[init]
	defaultBranch = main
[alias]
	# status / staging
	st = status -sb
	s = status -sb
	a = add
	aa = add -A
	unstage = reset HEAD --
	# commit
	ci = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	# branch / checkout
	co = checkout
	cob = checkout -b
	br = branch
	sw = switch
	swc = switch -c
	# diff
	d = diff
	dc = diff --cached
	ds = diff --stat
	# log
	lg = log --oneline --graph --decorate
	lga = log --oneline --graph --decorate --all
	last = log -1 HEAD
	ll = log --pretty=format:'%C(yellow)%h%Creset %s %C(green)(%cr) %C(blue)<%an>%Creset' --abbrev-commit
	# remote sync
	p = push
	pf = push --force-with-lease
	pl = pull
	f = fetch --all --prune
	# rebase / stash
	rb = rebase
	rbi = rebase -i
	rbc = rebase --continue
	sta = stash
	stp = stash pop
	# cleanup / undo
	undo = reset --soft HEAD~1
	nuke = reset --hard HEAD
	wip = !git add -A && git commit -m 'WIP'
	cleanup = !git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d
